{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist/extensions",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@zephyrdeng/pi-review": ["./src/index.ts"]
    }
  },
  "include": ["extensions/**/*.ts"],
  "exclude": ["node_modules"]
}
